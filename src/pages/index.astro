---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, CheckCircle2, Star, ShieldCheck, Clock4, Sparkles } from "lucide-react";

import { buttonVariants } from "@/components/ui/button";
import { BUSINESS, LINKS, SERVICES } from "@/lib/business";
import heroImg from "@/assets/hero-welding.jpg";

import { Picture } from "astro:assets";
---

<Layout title="Teralis Batam">
{/* Hero */}
      <section class="relative overflow-hidden bg-steel text-primary-foreground">
        <Picture src={heroImg} formats={['avif', 'webp']} alt="Tukang las stainless steel di workshop Teralis Batam" pictureAttributes={{ class: "absolute inset-0 h-full w-full" }} class="h-full w-full object-cover opacity-40" width={1600} height={1000} loading="eager" fetchpriority="high" />
        <div class="absolute inset-0 bg-gradient-to-r from-steel via-steel/90 to-steel/30" />
        <div class="absolute inset-0 bg-radial-spark" />
        <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-28 lg:py-36">
          <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 rounded-full border border-spark/40 bg-spark/10 px-3 py-1 text-xs font-medium text-spark">
              <Sparkles class="h-3.5 w-3.5" /> Sejak 2010 · {BUSINESS.legal}
            </div>
            <h1 class="mt-5 font-display text-4xl font-bold leading-[1.05] sm:text-5xl lg:text-6xl">
              Spesialis Besi & <span class="text-spark">Stainless Steel</span> Kualitas No.1 di Batam
            </h1>
            <p class="mt-5 max-w-xl text-base text-primary-foreground/80 sm:text-lg">
              Teralis, kanopi, railing tangga, rolling door, hingga konstruksi baja — dikerjakan rapi oleh tukang berpengalaman dengan garansi pengerjaan.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href={LINKS.whatsappQuote} target="_blank" rel="noreferrer" class={buttonVariants({ size: "lg", className: "bg-spark text-primary hover:bg-spark/90" })}>Konsultasi Gratis <ArrowRight class="ml-1 h-4 w-4" /></a>
              <a href="/services" class={buttonVariants({ size: "lg", variant: "outline", className: "border-white/30 bg-white/5 text-white hover:bg-white/15" })}>Lihat Layanan</a>
            </div>
            <div class="mt-10 grid max-w-lg grid-cols-3 gap-6 border-t border-white/10 pt-6">
              {[
                { v: BUSINESS.stats.years + "+", l: "Tahun" },
                { v: BUSINESS.stats.projects, l: "Proyek" },
                { v: BUSINESS.stats.rating, l: "Rating" },
              ].map((s) => (
                <div key={s.l}>
                  <div class="font-display text-2xl font-bold text-spark">{s.v}</div>
                  <div class="text-xs uppercase tracking-widest text-primary-foreground/60">{s.l}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* Sekilas */}
      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
        <div class="grid gap-12 md:grid-cols-2 md:items-center">
          <div>
            <div class="text-xs font-semibold uppercase tracking-widest text-spark">Sekilas Tentang</div>
            <h2 class="mt-3 font-display text-3xl font-bold sm:text-4xl">Bengkel fabrikasi besi terpercaya di Batam</h2>
            <p class="mt-5 text-muted-foreground">
              {BUSINESS.legal} fokus pada spesialis fabrikasi <strong>stainless steel & besi</strong>. Kami mengerjakan instalasi dan pembuatan teralis jendela, kanopi, railing tangga, spandek, tangga putar, konstruksi baja, baja ringan, dan semua pekerjaan besi lainnya.
            </p>
            <ul class="mt-6 space-y-2 text-sm">
              {["Tukang berpengalaman & rapi", "Material berkualitas SNI", "Garansi pengerjaan", "Survey & penawaran gratis"].map((t) => (
                <li key={t} class="flex items-center gap-2"><CheckCircle2 class="h-4 w-4 text-spark" />{t}</li>
              ))}
            </ul>
            <a href="/about" class={buttonVariants({ variant: "default", className: "mt-8" })}>Selengkapnya <ArrowRight class="ml-1 h-4 w-4" /></a>
          </div>
          <div class="relative">
            <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl shadow-brand">
              <Picture src={SERVICES[2].image} formats={['avif', 'webp']} alt="Railing stainless steel" pictureAttributes={{ class: "h-full w-full" }} class="h-full w-full object-cover" loading="lazy" />
            </div>
            <div class="absolute -bottom-6 -left-6 hidden rounded-xl bg-spark p-5 text-primary shadow-spark sm:block">
              <div class="font-display text-3xl font-bold">{BUSINESS.stats.years}+</div>
              <div class="text-xs uppercase tracking-widest">Tahun Pengalaman</div>
            </div>
          </div>
        </div>
      </section>

      {/* Layanan */}
      <section class="bg-muted/40 py-20">
        <div class="mx-auto max-w-7xl px-4 sm:px-6">
          <div class="mx-auto max-w-2xl text-center">
            <div class="text-xs font-semibold uppercase tracking-widest text-spark">Layanan Kami</div>
            <h2 class="mt-3 font-display text-3xl font-bold sm:text-4xl">Apa yang Kami Kerjakan</h2>
            <p class="mt-3 text-muted-foreground">Pilihan layanan fabrikasi besi & stainless steel untuk rumah, ruko, gudang, hingga proyek komersial.</p>
          </div>
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {SERVICES.map((s) => (
              <article key={s.slug} class="group overflow-hidden rounded-2xl bg-card shadow-card transition hover:-translate-y-1 hover:shadow-brand">
                <div class="aspect-[4/3] w-full overflow-hidden">
                  <Picture src={s.image} formats={['avif', 'webp']} alt={s.title} pictureAttributes={{ class: "h-full w-full" }} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
                </div>
                <div class="p-6">
                  <h3 class="font-display text-xl font-bold">{s.title}</h3>
                  <p class="mt-2 text-sm text-muted-foreground">{s.short}</p>
                  <ul class="mt-4 space-y-1.5 text-sm">
                    {s.features.map((f) => (
                      <li key={f} class="flex items-center gap-2"><CheckCircle2 class="h-4 w-4 text-spark" />{f}</li>
                    ))}
                  </ul>
                </div>
              </article>
            ))}
          </div>
          <div class="mt-10 text-center">
            <a href="/services" class={buttonVariants({ variant: "outline" })}>Lihat Semua Layanan</a>
          </div>
        </div>
      </section>

      {/* Why us */}
      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-display text-3xl font-bold sm:text-4xl">Kenapa Pilih Teralis Batam?</h2>
          <p class="mt-3 text-muted-foreground">Komitmen kami: hasil rapi, on-time, dan tanpa drama.</p>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {[
            { i: ShieldCheck, t: "Garansi Pengerjaan", d: "Setiap proyek didukung garansi rangka & finishing. Ada masalah, kami datang." },
            { i: Clock4, t: "Tepat Waktu", d: "Estimasi waktu jelas di awal. Kami komitmen selesai sesuai jadwal." },
            { i: Sparkles, t: "Hasil Rapi", d: "Las halus, sambungan presisi, finishing cat anti karat dengan standar workshop." },
          ].map((f) => (
            <div key={f.t} class="rounded-2xl border border-border bg-card p-6 shadow-card">
              <div class="grid h-12 w-12 place-items-center rounded-xl bg-spark/15 text-spark"><f.i class="h-6 w-6" /></div>
              <h3 class="mt-4 font-display text-lg font-bold">{f.t}</h3>
              <p class="mt-2 text-sm text-muted-foreground">{f.d}</p>
            </div>
          ))}
        </div>
      </section>

      {/* Testimonials */}
      <section class="bg-muted/40 py-20">
        <div class="mx-auto max-w-7xl px-4 sm:px-6">
          <div class="mx-auto max-w-2xl text-center">
            <h2 class="font-display text-3xl font-bold sm:text-4xl">Kata Klien Kami</h2>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-3">
            {[
              { n: "Pak Budi", r: "Pemilik Rumah, Batam Center", q: "Teralis & kanopi dikerjakan rapi banget, finishing-nya halus. Selesai sesuai jadwal." },
              { n: "Bu Linda", r: "Owner Ruko, Batu Aji", q: "Rolling door tebal, mekanismenya halus. Tim survey ramah dan harga transparan." },
              { n: "Pak Hendra", r: "Kontraktor", q: "Sudah langganan untuk pekerjaan railing stainless. Kualitas las-nya konsisten." },
            ].map((t) => (
              <figure key={t.n} class="rounded-2xl bg-card p-6 shadow-card">
                <div class="flex gap-1 text-spark">{[...Array(5)].map((_, i) => <Star key={i} class="h-4 w-4 fill-current" />)}</div>
                <blockquote class="mt-3 text-sm">"{t.q}"</blockquote>
                <figcaption class="mt-4 text-sm font-semibold">{t.n} <span class="font-normal text-muted-foreground">— {t.r}</span></figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>

      {/* CTA */}
      <section class="relative overflow-hidden bg-steel text-primary-foreground">
        <div class="absolute inset-0 bg-radial-spark" />
        <div class="relative mx-auto max-w-4xl px-4 py-20 text-center sm:px-6">
          <h2 class="font-display text-3xl font-bold sm:text-4xl">Siap Wujudkan Proyek Besi Anda?</h2>
          <p class="mt-3 text-primary-foreground/80">Konsultasi & survey GRATIS. Respon WhatsApp di jam kerja.</p>
          <div class="mt-7 flex flex-wrap justify-center gap-3">
            <a href={LINKS.whatsappQuote} target="_blank" rel="noreferrer" class={buttonVariants({ size: "lg", className: "bg-spark text-primary hover:bg-spark/90" })}>Chat WhatsApp Sekarang</a>
            <a href="/contact" class={buttonVariants({ size: "lg", variant: "outline", className: "border-white/30 bg-white/5 text-white hover:bg-white/15" })}>Lihat Lokasi</a>
          </div>
        </div>
      </section>
</Layout>
