---
import Layout from '../layouts/Layout.astro';
import { Button } from "@/components/ui/button";
import { CheckCircle2, ArrowRight } from "lucide-react";
import { LINKS, SERVICES } from "@/lib/business";

import { Image } from "astro:assets";
---

<Layout title="Teralis Batam">
<section class="bg-steel text-primary-foreground">
        <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20">
          <div class="text-xs font-semibold uppercase tracking-widest text-spark">Layanan</div>
          <h1 class="mt-3 font-display text-4xl font-bold sm:text-5xl">Apa yang Kami Kerjakan</h1>
          <p class="mt-4 max-w-2xl text-primary-foreground/80">Spesialis fabrikasi besi & stainless steel untuk rumah, ruko, gudang, dan proyek komersial di Batam dan sekitarnya.</p>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6">
        <div class="space-y-16">
          {SERVICES.map((s, i) => (
            <article key={s.slug} class="grid items-center gap-10 md:grid-cols-2">
              <div class={`overflow-hidden rounded-2xl shadow-brand ${i % 2 ? "md:order-2" : ""}`}>
                <Image src={s.image} alt={s.title} class="aspect-[4/3] w-full object-cover" loading="lazy" />
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-widest text-spark">Layanan {String(i + 1).padStart(2, "0")}</div>
                <h2 class="mt-2 font-display text-3xl font-bold">{s.title}</h2>
                <p class="mt-4 text-muted-foreground">{s.desc}</p>
                <ul class="mt-5 space-y-2">
                  {s.features.map((f) => (
                    <li key={f} class="flex items-center gap-2 text-sm"><CheckCircle2 class="h-4 w-4 text-spark" />{f}</li>
                  ))}
                </ul>
                <Button asChild class="mt-7 bg-spark text-primary hover:bg-spark/90">
                  <a href={LINKS.whatsappWith(`Halo, saya mau tanya layanan ${s.title}.`)} target="_blank" rel="noreferrer">
                    Tanya Harga <ArrowRight class="ml-1 h-4 w-4" />
                  </a>
                </Button>
              </div>
            </article>
          ))}
        </div>
      </section>
    </>
  );
}





</Layout>
