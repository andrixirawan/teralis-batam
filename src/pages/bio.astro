---
import Layout from '../layouts/Layout.astro';
import { MessageCircle, Phone, Mail, MapPin, Instagram, Facebook, Youtube, Globe } from "lucide-react";
import { BUSINESS, LINKS, SERVICES } from "@/lib/business";

import { Image } from "astro:assets";
---

<Layout title="Teralis Batam · Link in Bio" blank={true}>
    <div class="min-h-screen bg-gradient-to-br from-steel via-iron to-steel py-10 px-4">
      <div class="mx-auto max-w-md space-y-5">
        {/* Profile */}
        <div class="text-center text-primary-foreground">
          <div class="mx-auto grid h-20 w-20 place-items-center rounded-2xl bg-spark font-display text-3xl font-bold text-primary shadow-spark">TB</div>
          <h1 class="mt-4 font-display text-2xl font-bold">{BUSINESS.name}</h1>
          <p class="text-sm text-primary-foreground/70">{BUSINESS.tagline}</p>
          <p class="mt-1 text-xs text-primary-foreground/50">📍 {BUSINESS.city} · ⭐ {BUSINESS.stats.rating}</p>
        </div>

        {/* Primary CTA */}
        <a href={LINKS.whatsappQuote} target="_blank" rel="noreferrer"
          class="flex items-center justify-center gap-2 rounded-2xl bg-spark py-4 text-center font-semibold text-primary shadow-spark transition hover:scale-[1.02]">
          <MessageCircle class="h-5 w-5" /> Konsultasi via WhatsApp
        </a>

        {/* Social grid */}
        <div class="grid grid-cols-4 gap-3">
          {[
            { i: Instagram, l: "Instagram", h: LINKS.instagram, c: "from-pink-500 to-amber-500" },
            { i: Facebook, l: "Facebook", h: LINKS.facebook, c: "from-blue-600 to-blue-500" },
            { i: Youtube, l: "Youtube", h: LINKS.youtube, c: "from-red-600 to-red-500" },
            { i: Globe, l: "Web", h: LINKS.website, c: "from-slate-600 to-slate-500" },
          ].map((s) => (
            <a key={s.l} href={s.h} target="_blank" rel="noreferrer"
              class={`flex aspect-square flex-col items-center justify-center gap-1 rounded-2xl bg-gradient-to-br ${s.c} text-white text-xs font-medium shadow-card transition hover:scale-105`}>
              <s.i class="h-6 w-6" />
              <span>{s.l}</span>
            </a>
          ))}
        </div>

        {/* Services grid */}
        <div>
          <div class="mb-2 px-1 text-xs font-semibold uppercase tracking-widest text-spark">Layanan Kami</div>
          <div class="grid grid-cols-2 gap-3">
            {SERVICES.slice(0, 6).map((s) => (
              <a key={s.slug} href={LINKS.whatsappWith(`Halo, saya tertarik layanan ${s.title}.`)} target="_blank" rel="noreferrer"
                class="group relative aspect-[4/5] overflow-hidden rounded-2xl shadow-card">
                <Image src={s.image} alt={s.title} class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-steel via-steel/40 to-transparent" />
                <div class="absolute inset-x-0 bottom-0 p-3 text-primary-foreground">
                  <div class="font-display text-sm font-bold leading-tight">{s.title}</div>
                  <div class="mt-1 text-[10px] text-primary-foreground/70">Tap untuk tanya →</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        {/* Contact rows */}
        <div class="space-y-2">
          {[
            { i: Phone, l: BUSINESS.phones[0], h: LINKS.tel(BUSINESS.phones[0]) },
            { i: Mail, l: BUSINESS.email, h: LINKS.mail },
            { i: MapPin, l: "Lihat di Google Maps", h: LINKS.maps },
          ].map((c) => (
            <a key={c.l} href={c.h} target="_blank" rel="noreferrer"
              class="flex items-center gap-3 rounded-xl bg-white/5 px-4 py-3 text-sm text-primary-foreground backdrop-blur-md transition hover:bg-white/10">
              <c.i class="h-4 w-4 text-spark" />
              <span class="truncate">{c.l}</span>
            </a>
          ))}
        </div>

        <div class="pt-4 text-center text-[10px] text-primary-foreground/40">
          © {new Date().getFullYear()} {BUSINESS.legal}
        </div>
      </div>
    </div>
  );
}





</Layout>
