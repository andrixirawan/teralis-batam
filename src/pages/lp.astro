---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, CheckCircle2, X, Star, Clock4, ShieldCheck, Sparkles, Phone } from "lucide-react";
import { buttonVariants } from "@/components/ui/button";
import { FaqAccordion } from "@/components/FaqAccordion";
import { BUSINESS, LINKS, SERVICES } from "@/lib/business";
import { FloatingWhatsApp } from "@/components/floating-whatsapp";
import heroImg from "@/assets/hero-welding.jpg";

const painPoints = [
  "Vendor las sebelumnya hasilnya kasar & cepat karatan",
  "Sudah bayar mahal tapi finishing terlihat murahan",
  "Pengerjaan molor berminggu-minggu tanpa kabar",
  "Tukang datang tidak rapi, rumah jadi kotor",
  "Bingung pilih material yang awet untuk iklim Batam",
  "Takut kena harga 'orang baru' yang dimark-up",
];

const process = [
  { n: "01", t: "Chat & Survey GRATIS", d: "Kirim foto lokasi via WA. Kami datang ukur & beri rekomendasi.", time: "Hari 1" },
  { n: "02", t: "Penawaran Transparan", d: "RAB jelas — material, ukuran, dan harga tertulis. Tidak ada biaya kejutan.", time: "Hari 2" },
  { n: "03", t: "Fabrikasi & Pemasangan", d: "Dikerjakan di workshop, dipasang rapi di lokasi Anda.", time: "5–10 hari" },
  { n: "04", t: "Garansi & After-Sales", d: "Selesai dengan garansi pengerjaan. Ada keluhan, kami datang lagi.", time: "Selamanya" },
];

const faq = [
  { q: "Berapa lama pengerjaan teralis / kanopi?", a: "Tergantung volume. Rata-rata teralis 1 set rumah 5–7 hari kerja, kanopi 7–10 hari kerja. Estimasi pasti diberikan setelah survey." },
  { q: "Apakah ada garansi?", a: "Ya. Setiap pengerjaan kami berikan garansi rangka & finishing. Kalau ada masalah pemasangan, kami datang gratis." },
  { q: "Bagaimana sistem pembayarannya?", a: "Umumnya DP 50% setelah deal, pelunasan saat pemasangan selesai dan Anda puas." },
  { q: "Bisa survey ke rumah?", a: "Bisa dan GRATIS untuk area Batam. Cukup chat WA, sertakan alamat & foto lokasi." },
  { q: "Material apa yang dipakai?", a: "Kami pakai besi hollow / stainless 304 / spandek SNI sesuai pilihan paket. Kami sampaikan jujur kelebihan-kekurangannya." },
];

import { Picture } from "astro:assets";

const wa = LINKS.whatsappWith("Halo, saya mau ambil promo survey GRATIS Teralis Batam.");
---

<Layout title="Promo Teralis Batam — Survey Gratis, Garansi Pengerjaan" blank={true}>
    <div class="min-h-screen bg-background">
      {/* Top bar */}
      <div class="bg-spark text-primary text-center text-xs font-semibold py-2 px-4">
        🔥 PROMO BULAN INI · Survey GRATIS + Diskon 10% untuk 10 klien pertama
      </div>

      {/* Hero */}
      <section class="relative overflow-hidden bg-steel text-primary-foreground">
        <Picture src={heroImg} formats={['avif', 'webp']} alt="Workshop Teralis Batam" pictureAttributes={{ class: "absolute inset-0 h-full w-full" }} class="h-full w-full object-cover opacity-35" width={1600} height={1000} loading="eager" fetchpriority="high" />
        <div class="absolute inset-0 bg-gradient-to-r from-steel via-steel/95 to-steel/40" />
        <div class="absolute inset-0 bg-radial-spark" />
        <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 rounded-full border border-spark/40 bg-spark/10 px-3 py-1 text-xs font-medium text-spark">
              <Sparkles class="h-3.5 w-3.5" /> Spesialis Besi & Stainless Steel · Batam
            </div>
            <h1 class="mt-5 font-display text-4xl font-bold leading-[1.05] sm:text-5xl lg:text-6xl">
              Teralis & Kanopi <span class="text-spark">Anti Karat</span>, Selesai Tepat Waktu — Garansi Pengerjaan
            </h1>
            <p class="mt-5 max-w-2xl text-lg text-primary-foreground/85">
              Bengkel besi & stainless steel No.1 di Batam yang sudah dipercaya {BUSINESS.stats.clients} pelanggan. Hasil rapi, harga jujur, tanpa biaya kejutan.
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href={wa} target="_blank" rel="noreferrer" class={buttonVariants({ size: "lg", className: "bg-spark text-primary hover:bg-spark/90 text-base h-12 px-6" })}>Ya, Saya Mau Survey Gratis <ArrowRight class="ml-1 h-5 w-5" /></a>
              <a href={LINKS.tel(BUSINESS.phones[0])} class={buttonVariants({ size: "lg", variant: "outline", className: "border-white/30 bg-white/5 text-white hover:bg-white/15 h-12" })}><Phone class="mr-1 h-4 w-4" /> {BUSINESS.phones[0]}</a>
            </div>
            <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-primary-foreground/80">
              <div class="flex items-center gap-1 text-spark">{[...Array(5)].map((_, i) => <Star key={i} class="h-4 w-4 fill-current" />)}<span class="ml-1 text-primary-foreground/80">{BUSINESS.stats.rating}</span></div>
              <div>✓ {BUSINESS.stats.years}+ Tahun Pengalaman</div>
              <div>✓ {BUSINESS.stats.projects} Proyek Selesai</div>
              <div>✓ Garansi Pengerjaan</div>
            </div>
          </div>
        </div>
      </section>

      {/* Pain points */}
      <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
        <div class="text-center">
          <h2 class="font-display text-3xl font-bold sm:text-4xl">Apakah Anda Mengalami Ini?</h2>
          <p class="mt-3 text-muted-foreground">Frustrasi yang sering kami dengar dari klien sebelum bekerja dengan kami:</p>
        </div>
        <div class="mt-10 grid gap-3 sm:grid-cols-2">
          {painPoints.map((p) => (
            <div key={p} class="flex items-start gap-3 rounded-lg border border-border bg-card p-4 shadow-card">
              <X class="h-5 w-5 shrink-0 text-destructive" />
              <span class="text-sm">{p}</span>
            </div>
          ))}
        </div>
        <p class="mt-8 text-center text-muted-foreground">Jika salah satu di atas terasa familiar — <strong class="text-foreground">Anda berada di tempat yang tepat.</strong></p>
      </section>

      {/* Solution */}
      <section class="bg-muted/40 py-20">
        <div class="mx-auto max-w-5xl px-4 sm:px-6">
          <div class="text-center">
            <div class="text-xs font-semibold uppercase tracking-widest text-spark">Solusi Kami</div>
            <h2 class="mt-3 font-display text-3xl font-bold sm:text-4xl">Beda Kami dengan Bengkel Las Biasa</h2>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-3">
            {[
              { i: ShieldCheck, t: "Garansi Tertulis", d: "Bukan janji manis. Kami beri garansi pengerjaan yang bisa Anda klaim." },
              { i: Clock4, t: "Tepat Waktu, Tanpa Drama", d: "Estimasi waktu jelas di awal & laporan progress harian via WA." },
              { i: Sparkles, t: "Finishing Workshop", d: "Las halus, sambungan presisi, cat anti karat — bukan pengerjaan tukang dadakan." },
            ].map((f) => (
              <div key={f.t} class="rounded-2xl bg-card p-6 shadow-card">
                <div class="grid h-12 w-12 place-items-center rounded-xl bg-spark text-primary"><f.i class="h-6 w-6" /></div>
                <h3 class="mt-4 font-display text-lg font-bold">{f.t}</h3>
                <p class="mt-2 text-sm text-muted-foreground">{f.d}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Services */}
      <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
        <div class="text-center">
          <h2 class="font-display text-3xl font-bold sm:text-4xl">Yang Kami Kerjakan</h2>
        </div>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {SERVICES.map((s) => (
            <div key={s.slug} class="overflow-hidden rounded-2xl bg-card shadow-card">
              <div class="aspect-[4/3] w-full overflow-hidden">
                <Picture src={s.image} formats={['avif', 'webp']} alt={s.title} pictureAttributes={{ class: "h-full w-full" }} class="h-full w-full object-cover" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-display text-lg font-bold">{s.title}</h3>
                <p class="mt-1 text-sm text-muted-foreground">{s.short}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* Process */}
      <section class="bg-steel py-20 text-primary-foreground">
        <div class="mx-auto max-w-6xl px-4 sm:px-6">
          <div class="text-center">
            <h2 class="font-display text-3xl font-bold sm:text-4xl">Cara Kerja Kami — Simpel & Transparan</h2>
            <p class="mt-3 text-primary-foreground/70">Dari chat pertama sampai pemasangan selesai.</p>
          </div>
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {process.map((p) => (
              <div key={p.n} class="rounded-2xl border border-white/10 bg-white/5 p-6">
                <div class="font-display text-4xl font-bold text-spark">{p.n}</div>
                <h3 class="mt-3 font-display text-lg font-bold">{p.t}</h3>
                <p class="mt-2 text-sm text-primary-foreground/70">{p.d}</p>
                <div class="mt-3 inline-block rounded-full bg-spark/15 px-2.5 py-0.5 text-xs text-spark">⏱ {p.time}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Testimonials */}
      <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
        <div class="text-center">
          <h2 class="font-display text-3xl font-bold sm:text-4xl">{BUSINESS.stats.clients} Klien Sudah Merasakan Hasilnya</h2>
        </div>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {[
            { n: "Pak Budi · Batam Center", q: "Awalnya ragu karena pernah dikecewakan vendor lain. Tapi tim Teralis Batam survey detail, harga clear, dan hasilnya rapi sekali. Kanopi sudah 2 tahun masih kokoh." },
            { n: "Bu Linda · Pemilik Ruko", q: "Rolling door dipasang H+5 setelah deal. Mekanismenya halus, platnya tebal. Recommended buat yang punya ruko." },
            { n: "Pak Hendra · Kontraktor", q: "Sudah langganan untuk railing stainless. Konsisten kualitasnya. Saya tidak perlu ngecek tiap saat." },
          ].map((t) => (
            <figure key={t.n} class="rounded-2xl border border-border bg-card p-6 shadow-card">
              <div class="flex gap-1 text-spark">{[...Array(5)].map((_, i) => <Star key={i} class="h-4 w-4 fill-current" />)}</div>
              <blockquote class="mt-3 text-sm leading-relaxed">"{t.q}"</blockquote>
              <figcaption class="mt-4 text-sm font-semibold">{t.n}</figcaption>
            </figure>
          ))}
        </div>
      </section>

      {/* Scarcity */}
      <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
        <div class="rounded-2xl border-2 border-spark bg-spark/10 p-6 text-center sm:p-8">
          <div class="font-display text-sm uppercase tracking-widest text-spark">⚡ Penawaran Terbatas</div>
          <h3 class="mt-2 font-display text-2xl font-bold sm:text-3xl">Kami hanya terima 10 proyek baru bulan ini</h3>
          <p class="mt-2 text-muted-foreground">Untuk menjaga kualitas pengerjaan. Survey & konsultasi tetap GRATIS.</p>
          <a href={wa} target="_blank" rel="noreferrer" class={buttonVariants({ size: "lg", className: "mt-6 bg-spark text-primary hover:bg-spark/90" })}>Ambil Slot Survey GRATIS →</a>
        </div>
      </section>

      {/* FAQ */}
      <section class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
        <h2 class="text-center font-display text-3xl font-bold sm:text-4xl">Pertanyaan yang Sering Ditanya</h2>
        <FaqAccordion client:load faq={faq} />
      </section>

      {/* Final CTA */}
      <section class="relative overflow-hidden bg-steel text-primary-foreground">
        <div class="absolute inset-0 bg-radial-spark" />
        <div class="relative mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
          <h2 class="font-display text-3xl font-bold sm:text-4xl">Siap Pasang Teralis / Kanopi yang <span class="text-spark">Tahan Puluhan Tahun?</span></h2>
          <p class="mt-3 text-primary-foreground/80">Chat sekarang — tim kami respons di jam kerja. Tidak ada komitmen, tidak ada spam.</p>
          <div class="mt-7 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
            <a href={wa} target="_blank" rel="noreferrer" class={buttonVariants({ size: "lg", className: "bg-spark text-primary hover:bg-spark/90 text-base h-12 px-8" })}>Ya, Mau Konsultasi Gratis Sekarang →</a>
          </div>
          <div class="mt-4 flex flex-wrap justify-center gap-4 text-xs text-primary-foreground/60">
            <span>✓ Gratis konsultasi</span><span>✓ Survey GRATIS area Batam</span><span>✓ Respon &lt; 1 jam</span>
          </div>
          <ul class="mt-10 flex flex-wrap justify-center gap-4 border-t border-white/10 pt-6 text-sm text-primary-foreground/70">
            <li>📍 {BUSINESS.address}</li>
            <li>📞 {BUSINESS.phones[0]}</li>
          </ul>
        </div>
      </section>
      
    </div>
</Layout>
